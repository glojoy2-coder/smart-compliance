# Smart Compliance — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub!

# PostgreSQL (auto-provided by Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secrets (generate 64-char random strings)
JWT_SECRET=your_64_character_random_secret_here
ADMIN_JWT_SECRET=your_64_character_admin_secret_here

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@smartcompliance.com
SMTP_PASS=your_gmail_app_password_here
FROM_EMAIL=support@smartcompliance.com

# App URLs (set after Railway assigns your domain)
APP_URL=https://your-app.railway.app
SUCCESS_URL=https://your-app.railway.app/success.html
CANCEL_URL=https://your-app.railway.app/cancel.html
ALLOWED_ORIGINS=https://your-app.railway.app

# Server
PORT=3000
